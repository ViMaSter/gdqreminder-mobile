{
  "name": "gdq-reminder-mobile",
  "version": "7.3.1",
  "author": "Vincent Mahnke (vincent@mahn.ke)",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "launch": "npm run build && npx cap sync android && npx cap run android",
    "open": "npm run build && npx cap sync android && npx cap open android",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 4437",
    "test:unit": "vitest --environment jsdom",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "semantic-release": "semantic-release",
    "test:e2e": "playwright test -c playwright-ct.config.ts"
  },
  "dependencies": {
    "@capacitor-community/fcm": "^7.1.1",
    "@capacitor-firebase/authentication": "^7.2.0",
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/app-launcher": "^7.0.1",
    "@capacitor/core": "^7.1.0",
    "@capacitor/device": "^7.0.1",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/keyboard": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "@material/material-color-utilities": "^0.4.0",
    "@material/mwc-dialog": "^0.27.0",
    "@material/mwc-drawer": "^0.27.0",
    "@material/mwc-icon-button": "^0.27.0",
    "@material/mwc-top-app-bar-fixed": "^0.27.0",
    "@material/snackbar": "^14.0.0",
    "@material/web": "^2.3.0",
    "@sentry/cli": "^3.6.0",
    "@sentry/vue": "^10.65.0",
    "@vitejs/plugin-legacy": "^6.1.1",
    "@webcomponents/webcomponentsjs": "^2.8.0",
    "capacitor-plugin-safe-area": "4.0.0",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "firebase": "^11.8.1",
    "ky": "^2.0.2",
    "pinia": "^3.0.2",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@playwright/experimental-ct-vue": "^1.60.0",
    "@rushstack/eslint-patch": "^1.16.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@sentry/vite-plugin": "^5.4.0",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "*",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "semantic-release": "^25.0.6",
    "typescript": "~5.8.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ViMaSter/gdqreminder-mobile.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "release": {
    "branches": [
      {
        "name": "main"
      },
      {
        "name": "internal",
        "channel": "internal",
        "prerelease": "internal"
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits",
          "releaseRules": [
            {
              "type": "docs",
              "scope": "README",
              "release": "patch"
            },
            {
              "type": "refactor",
              "release": "patch"
            },
            {
              "type": "chore",
              "release": "patch"
            },
            {
              "type": "style",
              "release": "patch"
            },
            {
              "type": "test",
              "release": "patch"
            },
            {
              "type": "perf",
              "release": "patch"
            }
          ]
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "package-lock.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
